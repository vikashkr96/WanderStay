<% layout("layouts/boilerplate") %>
    <div class="row mt-3">
        <h1 class="col-6 offset-3">SignUp to WanderStay</h1> 
        <div class="col-6 offset-3">
            <form action="/signup" method="POST" class="needs-validation" novalidate>



                <div class="mb-3">
                    <label for="username" class="form-label fw-semibold">Username</label>
                    <input name="username" id="username" class="form-control rounded-3" type="text" required>
                    <div class="valid-feedback">Looks good</div>
                </div>
                
                <div class="mb-3">
                    <label for="email" class="form-label fw-semibold">Email</label>
                    <input name="email" id="email" class="form-control rounded-3" type="email" required>
                </div>

                <div class="mb-3">
                    <label for="password" class="form-label fw-semibold">Password</label>
                    <input name="password" id="password" class="form-control rounded-3" type="password" required>
                    <div class="valid-feedback">Looks good</div>
                </div>

                <button class="btn btn-success">SignUp</button> <br><br>

                


            </form>
        </div>
    </div>