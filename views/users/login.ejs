<% layout("layouts/boilerplate") %>
    <div class="row mt-3">
        <h1 class="col-6 offset-3">Login</h1> 
        <div class="col-6 offset-3">
            <form action="/login" method="POST" class="needs-validation" novalidate>



                <div class="mb-3">
                    <label for="username" class="form-label fw-semibold">Username</label>
                    <input name="username" id="username" class="form-control rounded-3" type="text" required>
                </div>

                <div class="mb-3">
                    <label for="password" class="form-label fw-semibold">Password</label>
                    <input name="password" id="password" class="form-control rounded-3" type="password" required>
                </div>

                <button class="btn btn-success">Login</button> <br><br>

                


            </form>
        </div>
    </div>