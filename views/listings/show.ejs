<% layout("layouts/boilerplate") %>
<script>
    const mapToken = "<%= process.env.MAP_TOKEN %>";
    const listing = <%- JSON.stringify(listing) %>;
</script>

<div class="container mt-5">
    <div class="row">
        <div class="col-lg-8 offset-lg-2">

            <!-- Title -->
            <h3 class="mb-4 fw-bold">
                <%= listing.title %>
            </h3>

            <!-- Image -->
            <img src="<%= listing.image.url %>" 
                 class="img-fluid rounded-4 shadow-sm mb-4"
                 style="height:300px;width:100%;object-fit:cover;">

            <!-- Listing Details -->
            <div class="mb-4">
                <p class="mb-1"><i>Owned by: <%= listing.owner.username %></i></p>
                <p class="mb-1"><%= listing.description %></p>
                <p class="mb-1">₹ <%= listing.price.toLocaleString("en-IN") %></p>
                <p class="mb-1"><%= listing.location %></p>
                <p class="mb-3"><%= listing.country %></p>

                <% if(currUser){ %>
                <!-- Edit & Delete Buttons -->
                <div class="d-flex gap-3 mb-4">
                    <a href="/listings/<%= listing._id %>/edit" class="btn btn-danger btn-sm px-4">
                        Edit
                    </a>
                    <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
                        <button class="btn btn-dark btn-sm px-4">Delete</button>
                    </form>
                </div>
                <% } %>

                <% if(currUser){ %>
                <hr>

                <!-- Review Form -->
                <h4 class="fw-bold mb-3">Leave a Review</h4>

                <form novalidate class="needs-validation"
                      action="/listings/<%= listing._id %>/reviews"
                      method="POST">

                    <!-- ⭐ Starability Rating -->
                    <div class="mb-3">
                        <label class="form-label">Rating</label>
                        <fieldset class="starability-slot">
                            <legend class="visually-hidden">Star Rating</legend>
                            <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="0" checked aria-label="No rating." />
                            <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                            <label for="first-rate1" title="Terrible">1 star</label>
                            <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                            <label for="first-rate2" title="Not good">2 stars</label>
                            <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                            <label for="first-rate3" title="Average">3 stars</label>
                            <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                            <label for="first-rate4" title="Very good">4 stars</label>
                            <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                            <label for="first-rate5" title="Amazing">5 stars</label>
                        </fieldset>
            
                        <div id="rating-error" style="display:none; color: #dc3545; font-size: 0.875em; margin-top: 4px;">
                            Please select a star rating before submitting.
                        </div>
                    </div>

                    <!-- Comment -->
                    <div class="mb-3">
                        <label for="comment" class="form-label">Comment</label>
                        <textarea name="review[comment]"
                                  id="comment"
                                  class="form-control"
                                  rows="4"
                                  placeholder="Write your comment here..."
                                  required></textarea>
                        <div class="invalid-feedback">Add some comments for review</div>
                    </div>

                    <button class="btn btn-success" id="review-submit-btn">Submit Review</button>
                </form>
                <% } %>

                <hr>
                <% if(listing.reviews.length > 0){ %> 
                <div class="row g-4">
                    <h5 class="fw-bold mb-3">All Reviews</h5>
                    <% for(review of listing.reviews){ %>
                    <div class="col-md-6">
                        <div class="card border-0 shadow-sm rounded-4 h-100">
                            <div class="card-body p-4">

                                <h6 class="card-title fw-bold text-primary mb-1">
                                    @<%= review.author ? review.author.username : "Anonymous" %>
                                </h6>

                                <!-- ⭐ Starability Display -->
                                <p class="starability-result" data-rating="<%= review.rating %>">
                                    Rated: <%= review.rating %> stars
                                </p>

                                <p class="card-text mb-3"><%= review.comment %></p>

                                <% if(currUser){ %>
                                <form method="POST"
                                      action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                                    <button class="btn btn-sm btn-danger">Delete</button>
                                </form>
                                <% } %> 
                            </div>
                        </div>
                    </div>
                    <% } %>
                </div>
                <hr>
                <% } %>
            </div>
            <div class="mb-3">
                    <h3>Where you'll be</h3>
                    <div id="map"></div>
            </div>
        </div>
    </div>
</div>

<script>
  document.querySelector('.needs-validation').addEventListener('submit', function(e) {
    const rating = document.querySelector('input[name="review[rating]"]:checked');
    const ratingVal = rating ? parseInt(rating.value) : 0;
    
    if (ratingVal < 1) {
      e.preventDefault();
      e.stopPropagation();
      document.getElementById('rating-error').style.display = 'block';
      return;
    }
    document.getElementById('rating-error').style.display = 'none';
  });

  document.querySelectorAll('input[name="review[rating]"]').forEach(input => {
    input.addEventListener('change', () => {
      document.getElementById('rating-error').style.display = 'none';
    });
  });
</script>

<script src="/js/map.js"></script>