<% layout("layouts/boilerplate") %>

<div class="container mt-5">
    <div class="row">
        <div class="col-lg-8 offset-lg-2">

            <!-- Title -->
            <h3 class="mb-4 fw-bold">
                <%= listing.title %>
            </h3>

            <!-- Image -->
            <img src="<%= listing.image %>" 
                 class="img-fluid rounded-4 shadow-sm mb-4"
                 style="height:300px;width:100%;object-fit:cover;">

            <!-- Listing Details -->
            <div class="mb-4">
                <p class="mb-1">  <i> Owened by: <%= listing.owner.username %> </i> </p>
                <p class="mb-1">  <%= listing.description %> </p>
                <p class="mb-1">₹ <%= listing.price.toLocaleString("en-IN") %> </p>

                <p class="mb-1">
                    <%= listing.location %>
                </p>

                <p class="mb-3">
                    <%= listing.country %>
                </p>

                <!-- Buttons --> 
                <div class="d-flex gap-3 mb-4">

                    <a href="/listings/<%= listing._id %>/edit" class="btn btn-danger btn-sm px-4">
                        Edit
                    </a>

                    <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
                        <button class="btn btn-dark btn-sm px-4">
                            Delete
                        </button>
                    </form>

                </div>

                <hr>

                <!-- Review Form -->
                <h4 class="mb-3">Leave a Review</h4>

                <form novalidate class="needs-validation"
                      action="/listings/<%= listing._id %>/reviews"
                      method="POST">

                    <!-- Rating -->
                    <div class="mb-3">
                        <label for="rating" class="form-label">
                            Rating
                        </label><br>

                        <input type="range"
                               min="1"
                               max="5"
                               id="rating"
                               name="review[rating]"
                               class="form-range w-50">
                    </div>

                    <!-- Comment -->
                    <div class="mb-3">
                        <label for="comment" class="form-label">
                            Comment
                        </label>

                        <textarea name="review[comment]"
                                  id="comment"
                                  class="form-control"
                                  rows="4"
                                  placeholder="Write your comment here..."
                                  required></textarea>

                        <div class="invalid-feedback">
                            Add some comments for review
                        </div>
                    </div>

                    <button class="btn btn-success greeen">
                        Submit Review
                    </button>

                </form>

                <hr>

                <h5 class="fw-bold mb-3">All Reviews</h5>

                <div class="row g-4">

                    <% for(review of listing.reviews){ %>

                    <div class="col-md-6">

                        <div class="card border-0 shadow-sm rounded-4 h-100">

                            <div class="card-body p-4">

                                <h6 class="card-title fw-bold text-primary mb-2">
                                    Guest
                                </h6>

                                <p class="card-text mb-3">
                                    <%= review.comment %>
                                </p>

                                <!-- Rating + Delete Button -->
                                <div class="d-flex justify-content-between align-items-center">

                                    <span class="badge bg-success px-3 py-2">
                                        Rating: <%= review.rating %> ⭐
                                    </span>

                                    <form method="POST"
                                          action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">

                                        <button class="btn btn-sm btn-danger">
                                            Delete
                                        </button>

                                    </form>

                                </div>

                            </div>

                        </div>

                    </div>

                    <% } %>

                </div>

            </div>

        </div>
    </div>
</div>